#!/bin/bash

vkcdn="$(inxi -G | grep -Pio 'Beema|Bonaire|Cape Verde|Carrizo|Durango|Godavari|Hawaii|Kabini|Kaveri|Liverpool|Mullins|Oland|Pitcairn|Tahiti|Temash')"
# OpenGL renderer codename, match against all known Sea/Southern Islands
if [ -z "$vkcdn" ]; then
  echo "No Sea/Southern Islands chipset on this sysytem."
else
  vkgpu="$(lspci -k | grep -EA3 'VGA|3D|Display')"
  # simple display of drivers
  vkuse="$(echo "$vkgpu" | grep -Pio 'driver.*')"
  # capture driver in use
  vkdrv="$(echo "$vkgpu" | grep -Pio 'modules.*')"
  # capture available drivers
  if [ -n "$(echo "$vkuse" | grep -Pio 'amdgpu')" ]; then
  # match if amdgpu in use, print and exit
    echo "Vulkan enabled on amdgpu, codename $vkcdn."
  elif [ -n "$(echo "$vkdrv" | grep -Pio 'amdgpu')" ]; then
  # match if amdgpu available
    if [ -n "$(echo "$vkcdn" | grep -Pio 'Cape Verde|Oland|Pitcairn|Tahiti')" ]; then
    # promote amdgpu for Sea Islands
      echo -e "  Vulkan not enabled on Sea Islands (SI)\n  GCN 1st gen chipset, codename $vkcdn\n  enabling..."
      echo -e 'options amdgpu si_support=1\noptions amdgpu cik_support=0\noptions radeon si_support=0\noptions radeon cik_support=0' | sudo tee /etc/modprobe.d/amdgpu.conf
      echo "To revert changes, delete /etc/modprobe.d/amdgpu.conf"
    else
    # promote amdgpu for Southern Islands
      echo -e "  Vulkan not enabled on Southern Islands (CIK)\n  GCN 2nd gen chipset, codename $vkcdn\n  enabling..."
      echo -e 'options amdgpu si_support=0\noptions amdgpu cik_support=1\noptions radeon si_support=0\noptions radeon cik_support=0' | sudo tee /etc/modprobe.d/amdgpu.conf
      echo "To revert changes, delete /etc/modprobe.d/amdgpu.conf"
    fi
  else
    echo "Vulkan amdgpu driver unavailable."
  fi
fi
