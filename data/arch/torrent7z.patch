diff a/torrent7z/PKGBUILD b/torrent7z/PKGBUILD
--- a/torrent7z/PKGBUILD	1969-12-31 17:00:00.000000000 -0700
+++ b/torrent7z/PKGBUILD	1969-12-31 17:00:00.000000000 -0700
@@ -0,0 +1,30 @@
+# Maintainer: Noa Body <noabody@archlinux.org>
+
+pkgname=torrent7z
+pkgver=1.3.r6.gcb2c3ab
+pkgrel=1
+arch=(x86_64)
+pkgdesc='7zip derivative that produces invariant .7z archives for torrenting.'
+url=https://github.com/BubblesInTheTub/torrent7z
+license=(GPL-3.0-only)
+depends=(glibc)
+source=(git+https://github.com/BubblesInTheTub/"$pkgname".git)
+sha256sums=('SKIP')
+
+pkgver() {
+  cd "$pkgname"
+  git describe --long --tags --abbrev=7 | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
+}
+
+prepare() {
+  make -C "$pkgname"/linux_src/p7zip_4.65 clean
+}
+
+build() {
+  make -C "$pkgname"/linux_src/p7zip_4.65 -j$(nproc)
+}
+
+package() {
+  install -Dm644 "$pkgname"/LICENSE -t "$pkgdir"/usr/share/licenses/"$pkgname"
+  install -Dm755 "$pkgname"/linux_src/p7zip_4.65/bin/t7z -t "$pkgdir"/usr/bin
+}
