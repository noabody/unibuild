diff a/buildgdx/PKGBUILD b/buildgdx/PKGBUILD
--- a/buildgdx/PKGBUILD	1969-12-31 17:00:00.000000000 -0700
+++ b/buildgdx/PKGBUILD	1969-12-31 17:00:00.000000000 -0700
@@ -0,0 +1,73 @@
+# Maintainer: Noa Body <noabody@archlinux.org>
+
+pkgname=buildgdx
+_pkgname=BuildGDX
+pkgver=1.18.r169.g236fec9
+pkgrel=1
+pkgdesc="Port of Build Engine games based on LibGDX."
+arch=(any)
+url=https://gitlab.com/m210/BuildGDX
+license=(GPL-2.0-only)
+depends=(bash hicolor-icon-theme)
+makedepends=(ant gendesk inkscape imagemagick jdk8-openjdk jdk17-openjdk jdk-openjdk maven)
+provides=("$pkgname")
+conflicts=("$pkgname")
+replaces=("$pkgname")
+source=(git+https://gitlab.com/m210/BuildGDX.git
+        git+https://gitlab.com/m210/BloodGDX.git
+        git+https://gitlab.com/m210/BuildGDX-Launcher.git
+        git+https://gitlab.com/m210/BuildSmaker.git
+        git+https://gitlab.com/m210/DukeGDX.git
+        git+https://gitlab.com/m210/LSPGDX.git
+        git+https://gitlab.com/m210/PowerslaveGDX.git
+        git+https://gitlab.com/m210/RedneckGDX.git
+        git+https://gitlab.com/m210/TekwarGDX.git
+        git+https://gitlab.com/m210/WangGDX.git
+        git+https://gitlab.com/m210/WitchavenGDX.git
+        "$pkgname".patch
+        "$pkgname".sh)
+
+sha256sums=('SKIP'
+            'SKIP'
+            'SKIP'
+            'SKIP'
+            'SKIP'
+            'SKIP'
+            'SKIP'
+            'SKIP'
+            'SKIP'
+            'SKIP'
+            'SKIP'
+            'ef1293861864e542a8609a688a3bbc62588b3d33af6c1be8eb88d471be895fe8'
+            'ac59aae32cd0dc724e57eab6a385f9e40d2f964df7114270e7dbd20e673cde56')
+
+pkgver() {
+  cd "$_pkgname"-Launcher
+  local _ver="$(grep -Pio "appvers.*\b.*\d+\.[[:alnum:]\.]+" src/ru/m210projects/Launcher/desktop/Main.java | grep -Pio '\d+\.[[:alnum:]\.]+')"
+  printf "%s.r%s.g%s" "$_ver" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
+}
+
+prepare() {
+  cd "$srcdir"
+  gendesk -f -n --name="$_pkgname" --comment="${pkgdesc/.}" --custom='Keywords=game;console;' --exec="$pkgname" --icon="$pkgname" --terminal=false --categories='GNOME;GTK;Game' --startupnotify=false --pkgname="$pkgname"
+  rm -rf *.gradle
+  patch -Np1 -i "$pkgname".patch
+  rm -rf {build,*/build}
+}
+
+build() {
+  if [ ! -f "$pkgname.svg" ]; then
+    magick "$_pkgname"-Launcher/res/Games/Blood/blood128.png -thumbnail 256x256 -strip "$pkgname".gif
+    inkscape "$pkgname".gif --export-plain-svg --export-filename="$pkgname".svg
+    rm -f "$pkgname".gif
+  fi
+  JAVA_HOME=/usr/lib/jvm/java-17-openjdk gradle clean build
+}
+
+package() {
+  install -dm 755 "$pkgdir"/usr/{bin,lib/"$pkgname",share/{applications,icons/hicolor/scalable/apps}}
+  install -m 755 "$pkgname".sh "$pkgdir"/usr/bin/"$pkgname"
+  install -m 644 "$pkgname".desktop "$pkgdir"/usr/share/applications/
+  install -m 644 "$pkgname".svg "$pkgdir"/usr/share/icons/hicolor/scalable/apps/
+  install -m 644 "$_pkgname"-Launcher/build/libs/"$_pkgname"-Launcher.jar "$pkgdir"/usr/lib/"$pkgname/$pkgname".jar
+}
diff a/buildgdx/buildgdx.sh b/buildgdx/buildgdx.sh
index e69de29..e223692 100755
--- a/buildgdx/buildgdx.sh	1969-12-31 17:00:00.000000000 -0700
+++ b/buildgdx/buildgdx.sh	1969-12-31 17:00:00.000000000 -0700
@@ -0,0 +1,37 @@
+#!/bin/bash
+gmdir="$HOME/games"
+gmcfg="$HOME/.m210projects"
+jre17="$(find /usr/lib/jvm -maxdepth 1 -type d -ipath '*/java*17*')"
+
+gconf () {
+test -d "$gmcfg" || mkdir -p "$gmcfg"
+echo "gamepath= $gmdir" | tee "$gmcfg/basedir"
+}
+
+gstart () {
+for value in BloodGDX-blood.rff DukeGDX-duke3d.grp LSPGDX-l0art000.dat NamGDX-nam.grp PowerslaveGDX-book.mov RedneckAgainGDX-makeout.con RedneckGDX-tornado.con WangGDX-sw.grp TekWarGDX-matrix.map WitchavenGDX-level35.map Witchaven2GDX-f_songs; do
+  gmtgt="${value%-*}"
+  gmini="${gmtgt,,}".ini
+  gmvfy="${value#*-}"
+  gmpth=$(find -H "$gmbdr" -maxdepth 2 -type f -iname "$gmvfy" -printf '%h\n')
+  test -d "$gmcfg/$gmtgt" || mkdir -p "$gmcfg/$gmtgt"
+  if [ ! -f "$gmcfg/$gmtgt/$gmini" ] && [ -n "$gmpth" ]; then
+    echo -e "[Main]\nPath = $gmpth" >> "$gmcfg/$gmtgt/$gmini"
+  fi
+done
+JAVA_HOME="$jre17" PATH="$jre17/bin:$PATH" java -jar /usr/lib/buildgdx/buildgdx.jar
+}
+
+gtest () {
+gmbse="$(grep -Pi '^gamepath=.*' "$gmcfg/basedir" | head -1)"
+gmbdr="${gmbse#gamepath= }"
+}
+
+test -f "$gmcfg/basedir" || gconf
+gtest
+if [ -z "$gmbdr" ]; then
+  gconf
+  gtest
+fi
+
+gstart
diff a/buildgdx/buildgdx.patch b/buildgdx/buildgdx.patch
index e69de29..e223692 100755
--- a/buildgdx/buildgdx.patch	1969-12-31 17:00:00.000000000 -0700
+++ b/buildgdx/buildgdx.patch	1969-12-31 17:00:00.000000000 -0700
@@ -0,0 +1,210 @@
+diff a/settings.gradle b/settings.gradle
+index e69de29..e223692 100755
+--- a/settings.gradle	1969-12-31 17:00:00.000000000 -0700
++++ b/settings.gradle	1969-12-31 17:00:00.000000000 -0700
+@@ -0,0 +1,12 @@
++rootProject.name = 'BuildGDX-Suite'
++
++include 'BuildGDX-Launcher'
++include 'BuildSmaker'
++include 'BloodGDX'
++include 'DukeGDX'
++include 'LSPGDX'
++include 'PowerslaveGDX'
++include 'RedneckGDX'
++include 'TekwarGDX'
++include 'WangGDX'
++include 'WitchavenGDX'
+diff a/build.gradle b/build.gradle
+index e69de29..e223692 100755
+--- a/build.gradle	1969-12-31 17:00:00.000000000 -0700
++++ b/build.gradle	1969-12-31 17:00:00.000000000 -0700
+@@ -0,0 +1,188 @@
++plugins {
++    id 'java'
++}
++
++allprojects {
++    apply plugin: 'java'
++
++    repositories {
++        mavenLocal()     
++        mavenCentral()   
++        
++        // 1. Core JetBrains compiler repository
++        maven { url 'https://www.jetbrains.com/intellij-repository/releases' }
++        
++        // 2. The missing link: JetBrains third-party dependency mirror for asm-all and jdom
++        maven { url 'https://packages.jetbrains.team/maven/p/ij/intellij-dependencies' }
++    }
++
++    tasks.withType(JavaCompile) {
++        options.encoding = 'UTF-8'
++        sourceCompatibility = JavaVersion.VERSION_17
++        targetCompatibility = JavaVersion.VERSION_17
++    }
++
++    tasks.withType(ProcessResources) {
++        duplicatesStrategy = DuplicatesStrategy.EXCLUDE
++    }
++}
++
++// --- DYNAMIC JAR INVENTORY ENGINE ---
++def unifiedLibs = fileTree("${rootDir}/BuildGDX")
++unifiedLibs.include '**/libs/**/*.jar'
++unifiedLibs.exclude '**/*unsafe*.jar'
++
++subprojects { subproj ->
++    if (subproj.name != 'BuildSmaker') {
++        dependencies {
++            implementation unifiedLibs
++        }
++    }
++}
++
++// --- MODULE ROUTING DEFINITIONS ---
++
++project(':BuildSmaker') {
++    sourceSets.main.java.srcDirs = ["${rootDir}/BuildSmaker/src"]
++}
++
++def configureGameEngine = { proj, gameName ->
++    proj.sourceSets.main {
++        java.srcDirs = [
++            "${rootDir}/BuildGDX/core/src",
++            "${rootDir}/BuildGDX/lwjgl3/src",
++            "${rootDir}/${gameName}/core/src"
++        ]
++        resources {
++            srcDirs = [
++                "${rootDir}/${gameName}/core/res",
++                "${rootDir}/BuildGDX/core/src",
++                "${rootDir}/BuildGDX/lwjgl3/src",
++                "${rootDir}/${gameName}/core/src"
++            ]
++            exclude '**/*.java'
++        }
++    }
++}
++
++project(':BloodGDX') {
++    dependencies { implementation project(':BuildSmaker') }
++    configureGameEngine(project, 'BloodGDX')
++}
++
++project(':DukeGDX') { configureGameEngine(project, 'DukeGDX') }
++project(':LSPGDX') { configureGameEngine(project, 'LSPGDX') }
++project(':PowerslaveGDX') { configureGameEngine(project, 'PowerslaveGDX') }
++project(':RedneckGDX') { configureGameEngine(project, 'RedneckGDX') }
++project(':TekwarGDX') {
++    dependencies { implementation project(':BuildSmaker') }
++    configureGameEngine(project, 'TekwarGDX')
++}
++project(':WangGDX') { configureGameEngine(project, 'WangGDX') }
++project(':WitchavenGDX') {
++    dependencies { implementation project(':BuildSmaker') }
++    configureGameEngine(project, 'WitchavenGDX')
++}
++
++// --- LAUNCHER ASSEMBLY AGGREGATOR ---
++
++project(':BuildGDX-Launcher') {
++    configurations {
++        formsCompiler
++    }
++
++    dependencies {
++        implementation project(':BuildSmaker')
++        implementation project(':BloodGDX')
++        implementation project(':DukeGDX')
++        implementation project(':LSPGDX')
++        implementation project(':PowerslaveGDX')
++        implementation project(':RedneckGDX')
++        implementation project(':TekwarGDX')
++        implementation project(':WangGDX')
++        implementation project(':WitchavenGDX')
++
++        // Include runtime layout binding dependencies cleanly
++        implementation 'com.intellij:forms_rt:7.0.3'
++        
++        // Dynamic cloud resolution for modern Java 17 bytecode instruments
++        formsCompiler 'com.jetbrains.intellij.java:java-compiler-ant-tasks:213.7172.53'
++    }
++
++    sourceSets.main {
++        java.srcDirs = [
++            "${rootDir}/BuildGDX-Launcher/src",
++            "${rootDir}/BuildGDX/core/src",
++            "${rootDir}/BuildGDX/lwjgl3/src",
++            "${rootDir}/BuildSmaker/src"
++        ]
++        resources {
++            srcDirs = [
++                "${rootDir}/BuildGDX-Launcher/res",
++                "${rootDir}/BloodGDX/core/res",
++                "${rootDir}/DukeGDX/core/res",
++                "${rootDir}/LSPGDX/core/res",
++                "${rootDir}/PowerslaveGDX/core/res",
++                "${rootDir}/RedneckGDX/core/res",
++                "${rootDir}/TekwarGDX/core/res",
++                "${rootDir}/WangGDX/core/res",
++                "${rootDir}/WitchavenGDX/core/res"
++            ]
++            exclude '**/*.java'
++        }
++    }
++
++    // Dynamic bytecode instrumentation pass
++    compileJava {
++        doLast {
++            if (!project.sourceSets.main.java.srcDirs.isEmpty()) {
++                ant.taskdef(
++                    name: 'javac2',
++                    classname: 'com.intellij.ant.Javac2',
++                    classpath: configurations.formsCompiler.asPath
++                )
++                ant.javac2(
++                    srcdir: project.sourceSets.main.java.srcDirs.join(':'),
++                    classpath: project.sourceSets.main.compileClasspath.asPath,
++                    destdir: project.sourceSets.main.java.classesDirectory.get().asFile,
++                    source: sourceCompatibility,
++                    target: targetCompatibility,
++                    includeAntRuntime: false
++                )
++            }
++        }
++    }
++
++    jar {
++        manifest {
++            attributes 'Main-Class': 'ru.m210projects.Launcher.desktop.Main'
++        }
++        from {
++            configurations.runtimeClasspath.collect { it.isDirectory() ? it : zipTree(it) }
++        } {
++            exclude '**/*.java'
++        }
++        from sourceSets.main.output
++        rootProject.subprojects.each { subproj ->
++            if (subproj.name != 'BuildGDX-Launcher') {
++                from subproj.sourceSets.main.output
++            }
++        }
++        duplicatesStrategy = DuplicatesStrategy.EXCLUDE
++    }
++}
++
++// --- AUTOMATIC MAVEN-LOCAL PUBLISHING ---
++apply plugin: 'maven-publish'
++
++publishing {
++    publications {
++        mavenJava(MavenPublication) {
++            groupId = 'ru.m210projects'
++            artifactId = 'buildgdx-launcher'
++            version = '1.13.0-SNAPSHOT'
++
++            artifact(project(':BuildGDX-Launcher').tasks.named('jar'))
++        }
++    }
++}
